# ─────────────────────────────────────────────
#  Environment variables — copy to .env
#  Never commit .env to version control
# ─────────────────────────────────────────────

# MongoDB Atlas connection string
# Get this from: Atlas → Connect → Drivers → copy connection string
# Format: mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/DATABASE_NAME
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mydb

# Session secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-secret

# Brain Token — your master API key (like a GitHub Personal Access Token)
# Anyone with this token can read/write to your brain.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave empty to run without authentication (not recommended for production)
BRAIN_TOKEN=

# Server port (default: 8080)
PORT=8080
